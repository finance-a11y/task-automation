{
  "name": "slack-clickup-task-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Slack → ClickUp NL-to-task bot on Vercel serverless. Phase 1: safe Slack events ingress (raw-body signature verify, ACK<3s via Fluid Compute waitUntil, event dedup, channel/message filter, in-thread receipt).",
  "type": "module",
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@slack/bolt": "^4.7.3",
    "@upstash/redis": "^1.35.0",
    "@vercel/functions": "^3.7.1",
    "@vercel/slack-bolt": "^1.5.0",
    "luxon": "^3.7.2",
    "openai": "^6.44.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/luxon": "^3.7.1",
    "@types/node": "^20.14.0",
    "typescript": "^5.6.0",
    "vercel": "^39.0.0",
    "vitest": "^2.1.0"
  }
}
