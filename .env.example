# ── Slack app credentials (Slack API → Your App → Basic Information / OAuth) ──
# Bot User OAuth token (xoxb-...): used to call the Slack Web API (post receipts).
SLACK_BOT_TOKEN=xoxb-your-bot-token
# Signing secret: Bolt verifies Slack's HMAC over the raw request body with this.
SLACK_SIGNING_SECRET=your-slack-signing-secret
# The single dedicated channel ID (C...) the bot listens to; other channels are ignored.
SLACK_TASK_CHANNEL_ID=C0123456789

# ── Upstash Redis (Vercel Marketplace → Upstash Redis, or Upstash console → REST API) ──
# REST endpoint URL for the Upstash Redis database (event dedup + later-phase state).
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# REST token paired with the URL above.
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# ── Team configuration ──
# Team timezone for relative-date resolution in later phases (default America/Caracas).
TEAM_TIMEZONE=America/Caracas

# ── OpenAI (Phase 2 NL parser — OpenAI Dashboard → API keys) ──
# API key (sk-...): used by the structured-outputs parser. Required in production; offline tests inject a mock.
OPENAI_API_KEY=sk-your-openai-key
# Chat model for extraction (default gpt-4o-mini — cheap, good Spanish; gpt-4.1-mini is the fallback).
OPENAI_MODEL=gpt-4o-mini

# ── ClickUp (Phase 3 Flow A — ClickUp → Settings → Apps → API token) ──
# Personal API token (pk_...) or OAuth token: used as the raw Authorization header (NOT "Bearer ").
CLICKUP_API_TOKEN=pk_your_clickup_token
# Destination list id for created tasks (default 901327239630 — Task-Seo Team list).
CLICKUP_LIST_ID=901327239630
